<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add a Book</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <header>
    <a href="/" class="btn-back">← Back to my books</a>
    <h1>Add a Book</h1>
  </header>

  <!-- ─── Add Book Form ────────────────────────────────────────────────────────
    action="/add" means when submitted, the browser sends a POST request to /add.
    method="POST" is required — without it the browser defaults to GET which
    won't trigger your app.post("/add") route.
  -->
  <form action="/add" method="POST" class="book-form">

    <!-- Title -->
    <div class="form-group">
      <label for="title">Book Title</label>
      <input
        type="text"
        id="title"
        name="title"
        placeholder="e.g. Atomic Habits"
        required
      >
    </div>

    <!-- Author -->
    <div class="form-group">
      <label for="author">Author</label>
      <input
        type="text"
        id="author"
        name="author"
        placeholder="e.g. James Clear"
        required
      >
    </div>

    <!-- ISBN ─────────────────────────────────────────────────────────────────
      This is what gets passed to the Open Library Covers API to fetch the
      book cover. Users can find the ISBN on the back of a book or on Google.
      It's optional — if left blank, a placeholder image will show instead.
    -->
    <div class="form-group">
      <label for="isbn">ISBN</label>
      <input
        type="text"
        id="isbn"
        name="isbn"
        placeholder="e.g. 9780735211292 (find on back of book)"
      >
      <small>Used to fetch the book cover automatically</small>
    </div>

    <!-- Rating -->
    <div class="form-group">
      <label for="rating">Your Rating (1–10)</label>
      <input
        type="number"
        id="rating"
        name="rating"
        min="1"
        max="10"
        placeholder="e.g. 8"
        required
      >
    </div>

    <!-- Date Read -->
    <div class="form-group">
      <label for="date_read">Date Read</label>
      <input
        type="date"
        id="date_read"
        name="date_read"
      >
    </div>

    <!-- Notes/Review -->
    <div class="form-group">
      <label for="notes">Your Notes / Review</label>
      <textarea
        id="notes"
        name="notes"
        rows="5"
        placeholder="What did you think? What were the key takeaways?"
      ></textarea>
    </div>

    <button type="submit" class="btn">Save Book</button>

  </form>

</body>
</html>